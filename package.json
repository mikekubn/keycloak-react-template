{
  "name": "keycloak-react-template",
  "version": "0.0.0",
  "description": "Keycloak React Template",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "rimraf dist dist_keycloak",
    "build": "tsc && vite build",
    "build-keycloak-theme": "pnpm build && keycloakify build",
    "pre:storybook": "pnpm tailwindcss -o ./tmp/storybook-tailwind.css --minify",
    "storybook": "pnpm pre:storybook && storybook dev -p 6006",
    "build:storybook": "pnpm pre:storybook && storybook build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prettier:fix": "biome format --write .",
    "lint:ts": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": ["pnpm prettier:fix", "pnpm lint:fix"]
  },
  "engines": {
    "node": ">=22.22.0",
    "npm": "Please use pnpm instead of npm to install dependencies",
    "yarn": "Please use pnpm instead of yarn to install dependencies",
    "pnpm": ">=10.28.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "keycloakify": "^11.15.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@chromatic-com/storybook": "^5.0.0",
    "@storybook/addon-a11y": "^10.2.1",
    "@storybook/addon-docs": "^10.2.1",
    "@storybook/addon-links": "^10.2.1",
    "@storybook/addon-onboarding": "^10.2.1",
    "@storybook/addon-vitest": "^10.2.1",
    "@storybook/react-vite": "^10.2.1",
    "@storybook/test-runner": "^0.24.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.21",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.45",
    "rimraf": "^6.1.3",
    "storybook": "^10.0.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^5.0.8",
    "vite-plugin-svgr": "^4.5.0"
  }
}
